# Lambda Cloud credentials
LAMBDA_API_KEY=your-api-key-here

# SSH key (must be added at cloud.lambda.ai -> SSH Keys)
SSH_KEY_NAME=your-ssh-key-name
SSH_KEY_PATH=~/.ssh/id_ed25519

# Persistent filesystem (create at cloud.lambda.ai -> Filesystems; must live
# in the same region as any instance that mounts it). Optional — if unset,
# lambda_run.sh launches without a persistent filesystem.
LAMBDA_FILESYSTEM_NAME=your-filesystem-name
LAMBDA_FILESYSTEM_ID=your-filesystem-id
LAMBDA_FILESYSTEM_MOUNT=/lambda/nfs/your-filesystem-name

# Instance config (lambda_run.sh auto-selects cheapest available GPU in the
# filesystem's region; override here if you want a specific type).
# INSTANCE_TYPE=gpu_1x_a100_sxm4
# REGION=us-east-1
